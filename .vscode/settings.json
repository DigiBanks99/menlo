{
  "chat.agent.maxRequests": 500,
  "chat.customAgentInSubagent.enabled": true,
  "chat.tools.terminal.autoApprove": {
    "rm": false,
    "rmdir": false,
    "del": false,
    "aspire run": true,
    "aspire start": true,
    "aspire stop": true,
    "aspire docs": true,
    "aspire doctor": true,
    "aspire logs": true,
    "aspire otel": true,
    "aspire help": true,
    "dotnet build": true,
    "dotnet restore": true,
    "dotnet outdated": true,
    "dotnet test": true,
    "pnpm i":true,
    "pnpm install": true,
    "pnpm build": true,
    "pnpm test": true,
    "kill": false,
    "curl": true,
    "wget": true,
    "eval": false,
    "chmod": false,
    "chown": false,
    "/^Remove-Item\\b/i": false,
    "pwsh ./scripts/act-ci.ps1": true
  },
  "chat.useAgentSkills": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.markdownlint": "always"
  },
  "files.associations": {
    "**/.github/workflows/*.yml": "github-actions-workflow"
  },
  "[markdown]": {
    "cSpell.fixSpellingWithRenameProvider": true,
    "cSpell.advanced.feature.useReferenceProviderWithRename": true,
    "cSpell.advanced.feature.useReferenceProviderRemove": "/^#+\\s/",
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.formatOnSave": true,
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "editor.unicodeHighlight.ambiguousCharacters": true,
    "editor.unicodeHighlight.invisibleCharacters": true,
    "editor.wordWrap": "on",
  },
  "markdown.extension.toc.levels": "2..6",
  "markdown.extension.toc.slugifyMode": "github",
  "markdown.extension.toc.updateOnSave": true,
  "markdownlint.configFile": ".config/.markdownlint-cli2.jsonc",
  "[mermaid]": {
    "editor.colorDecorators": true
  },
  "nxConsole.nxWorkspacePath": "src\\ui\\web",
  "terminal.integrated.shellIntegration.enabled": true,
  "debug.javascript.defaultRuntimeExecutable": {
    "pwa-node": "c:\\users\\wilco.boshoff\\appdata\\local\\mise\\shims\\node"
  }
}
