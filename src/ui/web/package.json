    "@tailwindcss/container-queries": "0.1.1",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "25.9.5",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/mocker": "^4.1.10",
