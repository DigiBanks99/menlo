{
  "name": "menlo-web",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "build-storybook:lib": "nx build-storybook menlo-lib",
    "build-storybook": "nx build-storybook menlo-app",
    "build:all:prod": "nx run-many --target=build --all --configuration=production",
    "build:all": "nx run-many --target=build --all",
    "build:prod": "nx build menlo-app --configuration=production",
    "build": "nx build menlo-app",
    "format": "nx format:write",
    "graph": "nx graph",
    "health-check": "curl -f http://localhost:4200/ || exit 1",
    "lint:affected": "nx affected --target=lint",
    "lint": "nx run-many --target=lint --all",
    "ng": "ng",
    "preview": "nx build menlo-app --configuration=production && npx http-server dist/menlo-app -p 4200",
    "start:prod": "nx serve menlo-app --configuration=production",
    "start": "nx serve menlo-app",
    "storybook:lib": "nx storybook menlo-lib",
    "storybook": "nx storybook menlo-app",
    "test:affected": "nx affected --target=test",
    "test:all": "nx run-many --target=test --all -- --coverage",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test": "nx run-many --target=test --all",
    "watch": "nx build menlo-app --watch"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "^21.2.19",
    "@angular/animations": "^21.2.18",
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/platform-browser-dynamic": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@fontsource/nunito-sans": "5.3.0",
    "apexcharts": "5.16.0",
    "lucide-angular": "1.0.0",
    "ng-apexcharts": "2.4.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "vite": "8.1.5",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^2.6.3",
    "@analogjs/vite-plugin-angular": "^2.6.3",
    "@analogjs/vitest-angular": "^2.6.3",
    "@angular-devkit/core": "^21.2.19",
    "@angular-devkit/schematics": "^21.2.19",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/eslintrc": "^3.3.6",
    "@nx/angular": "22.7.7",
    "@nx/eslint": "22.7.7",
    "@nx/eslint-plugin": "22.7.7",
    "@nx/js": "22.7.7",
    "@nx/vite": "22.7.7",
    "@nx/web": "22.7.7",
    "@nx/workspace": "22.7.7",
    "@playwright/test": "^1.61.1",
    "@schematics/angular": "^21.2.19",
    "@storybook/addon-docs": "10.5.2",
