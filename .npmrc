# Cross-platform pnpm configuration
# Works on Windows host, Linux CI, and devcontainer

# Use copy instead of hardlink/reflink for cross-platform compatibility
package-import-method=copy

# Ensure optional dependencies are installed (required for esbuild platform binaries)
optional=true

# Prevent unnecessary peer dependency warnings
auto-install-peers=true

# Disable minimum release age check — Dependabot PRs target trusted packages
# (Angular, Vite, etc.) at minor/patch only, so supply-chain risk is low.
minimum-release-age-seconds=0
